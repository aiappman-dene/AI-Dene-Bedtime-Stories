rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Stories are persisted client-side (localStorage / IndexedDB) at the
    // moment, so this collection is unused. Lock it down rather than leave
    // it world-readable. Re-enable with proper uid-scoping when needed.
    match /stories/{storyId} {
      allow read, write: if false;
    }

    // Job records (created by the server when a /generate request starts).
    // The owning user can poll their own jobs; nobody else can read or
    // mutate them. The server uses Admin SDK which bypasses these rules.
    match /jobs/{jobId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }
  }
}
